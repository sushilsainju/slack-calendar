# Slack App Credentials
# From https://api.slack.com/apps → your app → Basic Information
SLACK_SIGNING_SECRET=your-signing-secret

# Slack OAuth Credentials (required for multi-workspace support)
# From https://api.slack.com/apps → your app → Basic Information → App Credentials
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
# Random string for Slack OAuth state param — generate with: openssl rand -hex 32
SLACK_STATE_SECRET=your-64-hex-char-state-secret

# Phase 1→2 migration only — remove after SLACK_TEAM_ID tokens are migrated
# SLACK_BOT_TOKEN=xoxb-your-bot-token   # Seeds the installations table on first startup
# SLACK_TEAM_ID=T0123456789             # Your existing workspace team ID

# Google OAuth Credentials
# From https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match exactly what you set in Google Cloud Console
# Development: http://localhost:3000/oauth/google/callback
# Production: https://your-domain.com/oauth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# Server
PORT=3000

# Path to JSON file storing Google OAuth tokens (local dev only)
TOKEN_STORE_PATH=./tokens.json

# AES-256-GCM encryption key for Google tokens stored in Postgres
# Required when DATABASE_URL is set. Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-hex-char-key-here

# Postgres (Railway sets this automatically)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe (required for monetization)
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# From https://dashboard.stripe.com/webhooks — after adding the /stripe/webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Price IDs from https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_BUSINESS_PRICE_ID=price_your-business-price-id
# Public URL for Stripe checkout success/cancel redirects
APP_URL=https://your-domain.com
